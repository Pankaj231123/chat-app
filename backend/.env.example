PORT=8081

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=chatapp

JWT_SECRET=replace_with_a_long_random_secret

# Generate with: openssl rand -hex 32
MESSAGE_ENC_KEY=72d0e1826a657e960d5d7c37afd00939839acc962c82f5c5b79b2d4d709e333a

# Frontend base URL — used to build password reset links
APP_URL=http://localhost:5173

# SMTP — leave SMTP_HOST blank to use the no-op mailer (reset links logged to console)
# Gmail example: host=smtp.gmail.com port=587, use an App Password for SMTP_PASS
# Port 587 = STARTTLS  |  Port 465 = implicit TLS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Chat App <you@gmail.com>
